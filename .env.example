# Environment Configuration Template
# Copy this file to .env and fill in your values

# Weaviate Configuration
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8079
WEAVIATE_GRPC_PORT=50050

# LLM Configuration
# Choose your LLM provider:
# - Together AI: https://api.together.xyz/v1
# - OpenAI: https://api.openai.com/v1
# - Other OpenAI-compatible endpoints

LLM_MODEL=meta-llama/Llama-3.2-3B-Instruct-Turbo
LLM_API_KEY=your_api_key_here
LLM_API_BASE_URL=https://api.together.xyz/v1

# Example configurations:
# For Together AI:
# LLM_API_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3.2-3B-Instruct-Turbo

# For OpenAI:
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-3.5-turbo

# For local LLM (Ollama, LM Studio, etc):
# LLM_API_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama2

# Application Settings
MAX_TOKENS_DEFAULT=500
TEMPERATURE_DEFAULT=0.3
TOP_P_DEFAULT=0.8

# Query Routing Parameters
CREATIVE_TEMPERATURE=1.0
CREATIVE_TOP_P=0.9
TECHNICAL_TEMPERATURE=0.3
TECHNICAL_TOP_P=0.8

# Product Retrieval Settings
PRODUCT_LIMIT=20
MIN_RESULTS_THRESHOLD=5

# Flask Settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=False

# Logging
LOG_LEVEL=INFO
